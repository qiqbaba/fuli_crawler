# 本地开发环境变量模板
# 复制此文件为 .env 并填入真实值，.env 已被 .gitignore 忽略，不会提交到 Git

# ========== Supabase 配置 ==========
# 项目 URL，格式：https://xxxxxxxx.supabase.co
SUPABASE_URL=

# anon key 或 service_role key（推荐使用 service_role key 以获得写入权限）
SUPABASE_KEY=

# ========== Cloudflare R2 配置 ==========
# Cloudflare 账户 ID（在 Cloudflare Dashboard 右侧边栏可见）
R2_ACCOUNT_ID=

# R2 API Token 的 Access Key ID
R2_ACCESS_KEY_ID=

# R2 API Token 的 Secret Access Key
R2_SECRET_ACCESS_KEY=

# R2 Bucket 名称（需提前在 Cloudflare 创建）
R2_BUCKET_NAME=seju-pdfs

# R2 S3 兼容端点，格式：https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# ========== PDF 本地存储路径（仅本地开发未配置 R2 时生效）==========
# 云端运行时此变量由 GitHub Actions workflow 自动设置为 /tmp/seju_pdfs
PDF_BASE_DIR=d:\seju\pdf
